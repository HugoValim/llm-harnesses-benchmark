[run]
source = .
omit =
    venv/*
    */tests/*
    conftest.py
    manage.py
    */migrations/*
branch = True

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    @abstractmethod
show_missing = True
precision = 2
