# Environment variables for the Django Channels chat application

# OLLAMA_HOST: Base URL for the Ollama API
# Default: http://localhost:11434
OLLAMA_HOST=http://localhost:11434

# OLLAMA_MODEL: Model name to use with Ollama
# Default: qwen2.5:7b
OLLAMA_MODEL=qwen2.5:7b

# DJANGO_SECRET_KEY: Secret key for Django cryptographic signing
# This should be a long, random string. Keep it secret.
# Example: DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_SECRET_KEY=

# SECRET_KEY: Alias for DJANGO_SECRET_KEY (for compatibility)
SECRET_KEY=

# DEBUG: Enable Django debug mode
# Set to True for development, False for production
# Default: false
DEBUG=false
