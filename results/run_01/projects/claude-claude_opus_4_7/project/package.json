{
  "name": "ollama-chat-tailwind",
  "version": "1.0.0",
  "private": true,
  "description": "Tailwind CSS build pipeline for the Ollama chat SPA.",
  "scripts": {
    "build:css": "tailwindcss -i ./assets/css/input.css -o ./static/css/output.css --minify",
    "watch:css": "tailwindcss -i ./assets/css/input.css -o ./static/css/output.css --watch"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "tailwindcss": "^4.3.0"
  }
}
