# Copy to .env and adjust. Only non-secret configuration is documented here.
# Secret-shaped values are intentionally left blank with no placeholder.

# --- Ollama (not secrets) -------------------------------------------------
# Base URL of the Ollama server.
OLLAMA_HOST=http://localhost:11434
# Model tag to stream from. Pull it first: `ollama pull qwen2.5:7b`
OLLAMA_MODEL=qwen2.5:7b

# --- Django ---------------------------------------------------------------
# REQUIRED in production (DEBUG off). Leave blank here; generate your own with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=

# Enable Django debug mode locally (defaults to False / production-safe).
DJANGO_DEBUG=false

# Comma-separated allowed hosts (never "*"). Defaults to localhost,127.0.0.1.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated CSRF trusted origins (scheme + host).
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
