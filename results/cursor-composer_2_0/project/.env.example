# Copy to `.env` and adjust for local development (never commit `.env`).
#
# Ollama API base URL (default: http://localhost:11434)
OLLAMA_HOST=http://localhost:11434
#
# Ollama model tag (default: qwen2.5:7b)
OLLAMA_MODEL=qwen2.5:7b
#
# Django secret (required). No default — set a long random value locally.
# DJANGO_SECRET_KEY=
#
# Optional: enable Django debug in development (default: false)
# DJANGO_DEBUG=true
#
# Optional: comma-separated hosts (default: localhost,127.0.0.1)
# DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
